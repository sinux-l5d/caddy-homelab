{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "docker": {
    "enabled": true,
    "pinDigests": true
  },
  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["caddy"],
      "matchUpdateTypes": ["major"],
      "groupName": "caddy major",
      "automerge": false
    },
    {
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["caddy"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "caddy minor-patch",
      "ignoreTests": false,
      "automerge": true
    }
  ]
}
